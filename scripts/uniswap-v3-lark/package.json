{
  "name": "uniswap-v3-lark",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Deploy and validate Uniswap v3 as a native router venue on Hydration (lark)",
  "engines": {
    "node": ">=20.6"
  },
  "scripts": {
    "cli": "tsx src/cli.ts",
    "fund": "tsx src/cli.ts fund",
    "whitelist": "tsx src/cli.ts whitelist",
    "deploy": "tsx src/cli.ts deploy",
    "seed": "tsx src/cli.ts seed",
    "set-addresses": "tsx src/cli.ts set-addresses",
    "preflight": "tsx src/cli.ts preflight",
    "swap-test": "tsx src/cli.ts swap-test",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
