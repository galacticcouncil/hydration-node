# =============================================
#  Dispenser Test Configuration
# =============================================
# Copy this file to .env and fill in the values.
# Default values are set for Lark testnet + local Anvil.

# ---- Network selector ----
# Must be one of: local, sepolia, mainnet
NETWORK=sepolia

# ---- EVM (local Anvil) ----
EVM_RPC_URL=http://localhost:8545
EVM_CHAIN_ID=31337

# Uncompressed public key of the MPC root key (Anvil account 0).
# Derived from MPC_ROOT_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
# To regenerate: node pubKey.js
ROOT_PUBLIC_KEY=0x048318535b54105d4a7aae60c08fc45f9687181b4fdfc625bd1a753fa7397fed753547f11ca8696646f2f3acb08e31016afac23e630c5d11f59f61fef57b0d2aa5

# GasFaucet contract address on Anvil (deployed via forge script)
FAUCET_ADDRESS=0x189d33ea9A9701fdb67C21df7420868193dcf578

# ---- Substrate (Lark testnet) ----
SUBSTRATE_WS_ENDPOINT=wss://1.lark.hydration.cloud
SUBSTRATE_CHAIN_ID=polkadot:e6b50b06e72a81194e9c96c488175ecd
SS58_PREFIX=63

# ---- Test parameters ----
# Any valid Ethereum address to receive funds
TARGET_ADDRESS=0x7f67681ce8c292bbbef0ccfa1475d9742b6ab3ac
# Amount in wei (default: 0.000001 ETH)
REQUEST_FUND_AMOUNT_WEI=1000000000000

# ---- Gas (optional, sensible defaults) ----
GAS_LIMIT=100000
DEFAULT_MAX_FEE_PER_GAS=30000000000
DEFAULT_MAX_PRIORITY_FEE_PER_GAS=2000000000
